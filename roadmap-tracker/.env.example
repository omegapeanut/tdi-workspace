# Reuses the SAME Firebase project as the main tdi-workspace site (Firestore + Auth),
# just with its own collections and its own auth allow-list — copy the values from
# ../.env.local or the Firebase console (Project settings → General → Your apps).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" to point at the local Firestore/Auth emulators during development.
VITE_USE_FIREBASE_EMULATOR=false
