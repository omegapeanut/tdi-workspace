rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Public site content — world-readable, admin-writable
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /projects/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /articles/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /materials/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /media/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Leads: anyone may create (contact form / calculator); only admin reads or updates
    match /leads/{id} {
      allow create: if request.resource.data.keys().hasAll(['name', 'source', 'createdAt'])
        && request.resource.data.status == 'New';
      allow read, update, delete: if isAdmin();
    }

    // Admin allow-list: create docs here manually in the console, keyed by Auth UID.
    // Any signed-in admin may list all admin docs (Users & roles screen); writes stay console-only.
    match /admins/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || isAdmin());
      allow write: if false; // manage via Firebase console only
    }

    // --- roadmap-tracker (separate internal app, same Firebase project) ---
    // Fully private: every collection below requires a matching roadmapMembers/{uid}
    // doc, created manually in the console for each of the 4 teammates, shaped
    // { isAdmin: true|false }. Admins can restructure the roadmap (add/edit/delete
    // phases, KPI targets, discussion points, the team roster). Any member can operate
    // day-to-day: check off tasks, add/edit tasks within a phase, assign owners, bump
    // KPI progress counters, resolve discussion points, and post photo/notes updates.
    function isRoadmapMember() {
      return request.auth != null
        && exists(/databases/$(database)/documents/roadmapMembers/$(request.auth.uid));
    }
    function isRoadmapAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/roadmapMembers/$(request.auth.uid)).data.isAdmin == true;
    }
    function onlyChanged(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    match /phases/{id} {
      allow read: if isRoadmapMember();
      allow create, delete: if isRoadmapAdmin();
      // Members may freely manage the `tasks` map (add/edit/delete/check off tasks);
      // renaming the phase or editing its timeframe/summary/kpi chips stays admin-only.
      allow update: if isRoadmapAdmin() || (isRoadmapMember() && onlyChanged(['tasks']));
    }
    match /kpis/{id} {
      allow read: if isRoadmapMember();
      allow create, delete: if isRoadmapAdmin();
      // Members may bump the `current` counter; editing the label/target/unit is admin-only.
      allow update: if isRoadmapAdmin() || (isRoadmapMember() && onlyChanged(['current']));
    }
    match /discussionPoints/{id} {
      allow read: if isRoadmapMember();
      allow create, delete: if isRoadmapAdmin();
      // Members may resolve a point and leave notes; the point's text is admin-only.
      allow update: if isRoadmapAdmin() || (isRoadmapMember() && onlyChanged(['resolved', 'notes']));
    }
    match /roadmapMeta/{id} {
      allow read: if isRoadmapMember();
      allow write: if isRoadmapAdmin();
    }
    match /updates/{id} {
      // Photo/notes progress log — any member may post; only the author or an admin may delete.
      allow read: if isRoadmapMember();
      allow create: if isRoadmapMember() && request.resource.data.authorId == request.auth.uid;
      allow delete: if isRoadmapAdmin()
        || (isRoadmapMember() && resource.data.authorId == request.auth.uid);
      allow update: if false;
    }
    match /roadmapMembers/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || isRoadmapMember());
      allow write: if false; // manage via Firebase console only
    }

    // --- BusinessHQ (separate internal app, same Firebase project) ---
    // The `hqUsers/{uid}` doc IS the allow-list — its existence grants access,
    // and its `role` field (owner|admin|manager|employee) drives permissions,
    // matching the spec's simple model: Owner/Admin manage everything, a
    // Manager is scoped to their own department, an Employee to their own
    // work. Accounts are still provisioned by an Owner/Admin (Firebase
    // console for the Auth account + the in-app Settings page for the
    // profile doc) — there is no self-signup.
    function hqUser() {
      return get(/databases/$(database)/documents/hqUsers/$(request.auth.uid)).data;
    }
    function isHqMember() {
      return request.auth != null
        && exists(/databases/$(database)/documents/hqUsers/$(request.auth.uid));
    }
    function isHqAdmin() {
      return isHqMember() && hqUser().role in ['owner', 'admin'];
    }
    function isHqManagerOfDept(departmentId) {
      return isHqMember() && hqUser().role == 'manager' && hqUser().departmentId == departmentId;
    }

    match /hqUsers/{uid} {
      allow read: if isHqMember();
      // Admins manage the roster; anyone may update their own availability.
      allow create, delete: if isHqAdmin();
      allow update: if isHqAdmin()
        || (request.auth != null && request.auth.uid == uid && onlyChanged(['availability', 'updatedBy', 'updatedAt']));
    }
    match /hqDepartments/{id} {
      allow read: if isHqMember();
      allow write: if isHqAdmin();
    }
    match /hqGoals/{id} {
      allow read: if isHqMember();
      // Company-level goals are admin-only; department goals may also be
      // managed by that department's manager.
      allow create: if isHqAdmin() || isHqManagerOfDept(request.resource.data.departmentId);
      allow update, delete: if isHqAdmin() || isHqManagerOfDept(resource.data.departmentId);
    }
    match /hqProjects/{id} {
      allow read: if isHqMember();
      // Day-to-day project work (status, membership, milestones/tasks inside
      // it) is open to any signed-in teammate on purpose, same rationale as
      // the roadmap tracker: small trusted team, optimize for collaboration
      // over gatekeeping routine updates.
      allow create, update: if isHqMember();
      allow delete: if isHqAdmin();
    }
    match /hqMilestones/{id} {
      allow read: if isHqMember();
      allow write: if isHqMember();
    }
    match /hqTasks/{id} {
      allow read: if isHqMember();
      allow write: if isHqMember();
    }
    match /hqComments/{id} {
      allow read: if isHqMember();
      allow create: if isHqMember() && request.resource.data.authorId == request.auth.uid;
      allow delete: if isHqAdmin() || (isHqMember() && resource.data.authorId == request.auth.uid);
      allow update: if false; // append-only
    }
    match /hqActivity/{id} {
      allow read: if isHqMember();
      allow create: if isHqMember() && request.resource.data.actorId == request.auth.uid;
      allow update, delete: if false; // immutable log
    }
    match /hqKpis/{id} {
      allow read: if isHqMember();
      // Assigning/retargeting KPIs is admin-only; any member may bump their
      // own progress numbers day-to-day.
      allow create, delete: if isHqAdmin();
      allow update: if isHqAdmin() || (isHqMember() && onlyChanged(['current', 'history', 'updatedBy', 'updatedAt']));
    }
    match /hqAnnouncements/{id} {
      allow read: if isHqMember();
      allow write: if isHqAdmin();
    }
  }
}
