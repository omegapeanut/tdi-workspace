rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Public site content — world-readable, admin-writable
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /projects/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /articles/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /materials/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /media/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Leads: anyone may create (contact form / calculator); only admin reads or updates
    match /leads/{id} {
      allow create: if request.resource.data.keys().hasAll(['name', 'source', 'createdAt'])
        && request.resource.data.status == 'New';
      allow read, update, delete: if isAdmin();
    }

    // Admin allow-list: create docs here manually in the console, keyed by Auth UID.
    // Any signed-in admin may list all admin docs (Users & roles screen); writes stay console-only.
    match /admins/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || isAdmin());
      allow write: if false; // manage via Firebase console only
    }

    // --- roadmap-tracker (separate internal app, same Firebase project) ---
    // Fully private: every collection below requires a matching roadmapMembers/{uid}
    // doc, created manually in the console for each of the 4 teammates.
    function isRoadmapMember() {
      return request.auth != null
        && exists(/databases/$(database)/documents/roadmapMembers/$(request.auth.uid));
    }
    match /phases/{id} {
      allow read, write: if isRoadmapMember();
    }
    match /kpis/{id} {
      allow read, write: if isRoadmapMember();
    }
    match /discussionPoints/{id} {
      allow read, write: if isRoadmapMember();
    }
    match /roadmapMeta/{id} {
      allow read, write: if isRoadmapMember();
    }
    match /roadmapMembers/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || isRoadmapMember());
      allow write: if false; // manage via Firebase console only
    }
  }
}
